# ── Required ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_groq_api_key_here          # Groq API key (named OPENAI_API_KEY for compatibility)

# ── Security ───────────────────────────────────────────────────────────────────
PASSWORD_PEPPER=change-this-to-a-random-secret  # Add a unique secret string here
SESSION_TIMEOUT_MINUTES=60
MAX_FILE_SIZE_MB=10

# ── OAuth2 (optional) ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
OAUTH2_REDIRECT_URI=http://localhost:8501/oauth2/callback

# ── URL whitelist (optional, comma-separated) ──────────────────────────────────
# Leave blank to allow all domains for case URL fetching
ALLOWED_URL_DOMAINS=

# ── App tuning ─────────────────────────────────────────────────────────────────
GROQ_MODEL=llama-3.1-8b-instant
RESPONSE_CACHE_TTL=300                          # seconds to cache identical queries
DB_PATH=legal_ai.db

# ── Streamlit ──────────────────────────────────────────────────────────────────
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost
