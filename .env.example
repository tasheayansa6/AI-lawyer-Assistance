# ── Required ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=your_groq_api_key_here

# ── Security ───────────────────────────────────────────────────────────────────
PASSWORD_PEPPER=change-this-to-a-random-secret-string
SESSION_TIMEOUT_MINUTES=60
MAX_FILE_SIZE_MB=10

# ── OAuth2 (optional) ──────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
MICROSOFT_CLIENT_ID=your_microsoft_application_client_id
MICROSOFT_CLIENT_SECRET=your_microsoft_client_secret_value
OAUTH2_REDIRECT_URI=http://localhost:8501/

# ── URL whitelist (optional, comma-separated) ──────────────────────────────────
# Leave blank to allow all domains for case URL fetching
ALLOWED_URL_DOMAINS=

# ── App tuning ─────────────────────────────────────────────────────────────────
GROQ_MODEL=llama-3.1-8b-instant
RESPONSE_CACHE_TTL=300
DB_PATH=legal_ai.db

# ── Streamlit ──────────────────────────────────────────────────────────────────
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=localhost
